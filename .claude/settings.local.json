{
  "permissions": {
    "allow": [
      "Bash(mise x:*)",
      "Bash(grep -E \"\\\\.rb$\")",
      "mcp__acp__Write",
      "mcp__acp__Bash",
      "WebFetch(domain:daisyui.com)",
      "WebFetch(domain:www.e-solat.gov.my)",
      "WebFetch(domain:github.com)",
    ]
  },
  "model": "opus",
  "skills": {
    "autoLoad": true,
    "path": "~/.claude/skills"
  },
  "agents": {
    "path": "~/.claude/agents",
    "default": "fullstack-rails"
  },
  "project": "solat.my",
  "rails_version": "8.1.3"
}
